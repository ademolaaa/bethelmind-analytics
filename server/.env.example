# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Lead Scoring Configuration
LEAD_SCORING_BATCH_SIZE=10
LEAD_SCORING_CACHE_TTL=3600000

# Rate Limiting
GEMINI_RATE_LIMIT_DELAY=500

# Academic Writing Service Configuration
SERVICE_KEYWORDS=thesis,dissertation,research,academic,proposal,literature review,methodology,data analysis
HIGH_VALUE_KEYWORDS=PhD,master's,doctoral,graduate,university
URGENCY_KEYWORDS=urgent,deadline,asap,emergency,rush